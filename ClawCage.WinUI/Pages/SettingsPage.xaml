<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClawCage.WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="24,20,24,24">
        <StackPanel Spacing="4">

            <!-- ── Section: 常规 ── -->
            <TextBlock Text="常规"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="4,0,0,4"/>

            <!-- 数据存放路径 -->
            <Border CornerRadius="8"
                    BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B7;"
                              FontSize="18" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="数据存放路径"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="PathPreview"
                                   FontFamily="Cascadia Mono" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="浏览…"
                            MinWidth="72" Height="32"
                            VerticalAlignment="Center"
                            Click="ChangePath_Click"/>
                </Grid>
            </Border>

            <InfoBar x:Name="SavedInfoBar"
                     Title="路径已更新，重启后生效。"
                     Severity="Success"
                     IsOpen="False" IsClosable="True"
                     Margin="0,0,0,4"/>

            <!-- 运行模式 -->
            <Border CornerRadius="8"
                    BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE839;"
                              FontSize="18" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="运行模式"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="切换网关模式 / 节点模式"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <ToggleSwitch x:Name="RunModeSwitch"
                                  Grid.Column="2"
                                  OnContent="" OffContent=""
                                  MinWidth="0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Toggled="RunModeSwitch_Toggled"/>
                </Grid>
            </Border>

            <!-- 节点参数 (仅节点模式) -->
            <Border x:Name="NodeArgsPanel"
                    CornerRadius="8"
                    BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="HostTextBox"
                                 Header="网关地址"
                                 PlaceholderText="例如 127.0.0.1"
                                 LostFocus="NodeArgs_LostFocus"/>

                        <TextBox x:Name="PortTextBox"
                                 Grid.Column="1"
                                 Header="网关端口"
                                 PlaceholderText="例如 3000"
                                 InputScope="Number"
                                 LostFocus="NodeArgs_LostFocus"/>
                    </Grid>

                    <InfoBar x:Name="RunModeInfoBar"
                             Severity="Success"
                             IsOpen="False" IsClosable="True"/>
                </StackPanel>
            </Border>

            <!-- ── Section: OpenClaw ── -->
            <TextBlock Text="OpenClaw"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="4,12,0,4"/>

            <!-- 插件系统 -->
            <Border CornerRadius="8"
                    BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEA86;"
                              FontSize="18" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="插件系统"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="启用后允许加载已安装的插件扩展。"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <ToggleSwitch x:Name="PluginsEnabledToggle"
                                  Grid.Column="2"
                                  OnContent="" OffContent=""
                                  MinWidth="0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Toggled="PluginsEnabledToggle_Toggled"/>
                </Grid>
            </Border>

            <!-- 配置文件 -->
            <Border CornerRadius="8"
                    BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7C3;"
                              FontSize="18" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="配置文件"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="OpenClawConfigPathText"
                                   FontFamily="Cascadia Mono" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>

                    <TextBlock x:Name="OpenClawConfigStatusText"
                               Grid.Column="2"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </Border>

            <!-- ── Section: 更新 ── -->
            <TextBlock Text="更新"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="4,12,0,4"/>

            <!-- 更新 OpenClaw -->
            <Border CornerRadius="8"
                    BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE895;"
                              FontSize="18" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="更新 OpenClaw"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="当前"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="CurrentVersionText"
                                           Text="获取中…"
                                           FontFamily="Cascadia Mono" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="最新"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="LatestVersionText"
                                           Text="获取中…"
                                           FontFamily="Cascadia Mono" FontSize="11"/>
                            </StackPanel>
                            <TextBlock x:Name="UpdateStatusText"
                                       Text=""
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="UpdateButton"
                            Grid.Column="2"
                            MinWidth="90" Height="32"
                            VerticalAlignment="Center"
                            Click="UpdateButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" FontSize="13"/>
                            <TextBlock Text="检查更新" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <InfoBar x:Name="UpdateInfoBar"
                     Severity="Success"
                     IsOpen="False" IsClosable="True"
                     Margin="0,0,0,4"/>

        </StackPanel>
    </ScrollViewer>
</Page>
