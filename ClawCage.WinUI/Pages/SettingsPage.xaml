<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClawCage.WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="24,20,24,24">
        <StackPanel Spacing="8">

            <!-- Section: 数据存储 -->
            <TextBlock Text="数据存储"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="4,0,0,2"/>

            <!-- 数据存放路径 -->
            <Expander HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <Grid ColumnSpacing="14" Margin="0,6"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B7;"
                                  FontSize="18" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="数据存放路径"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="数据库文件的存储位置，修改后需重启应用生效。"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <TextBlock x:Name="PathPreview"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   FontFamily="Cascadia Mono"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"
                                   Margin="0,0,8,0"/>
                    </Grid>
                </Expander.Header>

                <!-- 展开内容 -->
                <StackPanel Spacing="8" Padding="0,4,0,6">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PathTextBox"
                                 IsReadOnly="True"
                                 PlaceholderText="（使用默认路径）"
                                 FontFamily="Cascadia Mono"
                                 FontSize="12"/>

                        <Button Grid.Column="1"
                                Content="浏览…"
                                MinWidth="80"
                                VerticalAlignment="Stretch"
                                Click="ChangePath_Click"/>
                    </Grid>

                    <InfoBar x:Name="SavedInfoBar"
                             Title="路径已更新，重启后生效。"
                             Severity="Success"
                             IsOpen="False"
                             IsClosable="True"/>
                </StackPanel>
            </Expander>

            <TextBlock Text="运行设置"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="4,8,0,2"/>

            <Expander HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <Grid ColumnSpacing="14" Margin="0,6"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="运行模式"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="切换网关模式 / 节点模式"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <ToggleSwitch x:Name="RunModeSwitch"
                                      Grid.Column="1"
                                      OffContent="网关模式"
                                      OnContent="节点模式"
                                      VerticalAlignment="Center"
                                      Toggled="RunModeSwitch_Toggled"/>
                    </Grid>
                </Expander.Header>

                <StackPanel Spacing="8" Padding="0,4,0,6">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="HostTextBox"
                                 Header="网关地址"
                                 PlaceholderText="例如 127.0.0.1"
                                 LostFocus="NodeArgs_LostFocus"/>

                        <TextBox x:Name="PortTextBox"
                                 Grid.Column="1"
                                 Header="网关端口"
                                 PlaceholderText="例如 3000"
                                 InputScope="Number"
                                 LostFocus="NodeArgs_LostFocus"/>
                    </Grid>

                    <InfoBar x:Name="RunModeInfoBar"
                             Severity="Success"
                             IsOpen="False"
                             IsClosable="True"/>
                </StackPanel>
            </Expander>

            <TextBlock Text="OpenClaw 配置"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="4,8,0,2"/>

            <!-- 插件总开关 -->
            <Border CornerRadius="8"
                    BorderThickness="1"
                    Padding="12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEA86;"
                              FontSize="18" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="插件系统"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="启用后允许加载已安装的插件扩展。"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <ToggleSwitch x:Name="PluginsEnabledToggle"
                                  Grid.Column="2"
                                  OnContent="已启用" OffContent="已禁用"
                                  VerticalAlignment="Center"
                                  Toggled="PluginsEnabledToggle_Toggled"/>
                </Grid>
            </Border>

            <Border CornerRadius="8"
                    BorderThickness="1"
                    Padding="12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="配置文件路径"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="OpenClawConfigPathText"
                               FontFamily="Cascadia Mono"
                               FontSize="12"
                               TextWrapping="WrapWholeWords"/>
                    <TextBlock x:Name="OpenClawConfigStatusText"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
