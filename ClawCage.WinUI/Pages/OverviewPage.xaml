<Page x:Class="ClawCage.WinUI.Pages.OverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Width="42"
                Height="42"
                CornerRadius="21"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Command="{x:Bind ViewModel.HelpCommand}"
                IsEnabled="{x:Bind ViewModel.IsHelpEnabled, Mode=OneWay}">
            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE897;" FontSize="18"/>
            <ToolTipService.ToolTip>
                <ToolTip Content="帮助"/>
            </ToolTipService.ToolTip>
        </Button>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
            <TextBlock HorizontalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"/>
            <ProgressRing Width="42" Height="42" IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Visibility="{x:Bind ViewModel.BusyVisibility, Mode=OneWay}"/>
            <TextBlock HorizontalAlignment="Center" Opacity="0.8" Visibility="{x:Bind ViewModel.BusyVisibility, Mode=OneWay}" Text="{x:Bind ViewModel.BusyText, Mode=OneWay}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Visibility="{x:Bind ViewModel.ActionButtonsVisibility, Mode=OneWay}">
                <Button MinWidth="136" Height="46" Padding="16,0" Command="{x:Bind ViewModel.RunCommand}" Background="{x:Bind ViewModel.RunButtonBackground, Mode=OneWay}" Foreground="{x:Bind ViewModel.RunButtonForeground, Mode=OneWay}">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black"/>
                        <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#80FFFFFF"/>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="{x:Bind ViewModel.RunButtonGlyph, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.RunButtonText, Mode=OneWay}"/>
                    </StackPanel>
                </Button>

                <Button MinWidth="120" Height="42" Content="控制台" Command="{x:Bind ViewModel.OpenConsoleCommand}" Visibility="{x:Bind ViewModel.OpenConsoleVisibility, Mode=OneWay}"/>
                <Button MinWidth="100" Height="42" Content="重启" Command="{x:Bind ViewModel.RestartCommand}" Visibility="{x:Bind ViewModel.RestartButtonVisibility, Mode=OneWay}"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Page>
