<Page x:Class="ClawCage.WinUI.Pages.OverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Padding="24">

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
            <TextBlock x:Name="StatusText" HorizontalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="OpenClaw Overview"/>
            <ProgressRing x:Name="BusyRing" Width="42" Height="42" IsActive="False" Visibility="Collapsed"/>
            <TextBlock x:Name="BusyText" HorizontalAlignment="Center" Opacity="0.8" Visibility="Collapsed" Text="Working..."/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                <Button x:Name="RunButton" MinWidth="120" Height="42" Click="RunButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="RunButtonIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE8FB;"/>
                        <TextBlock x:Name="RunButtonText" Text="Initialize"/>
                    </StackPanel>
                </Button>

                <Button x:Name="HelpButton" MinWidth="100" Height="42" Content="Help" Click="HelpButton_Click"/>
                <Button x:Name="OpenConsoleButton" MinWidth="120" Height="42" Content="打开控制台" Click="OpenConsoleButton_Click"/>
                <Button x:Name="RestartButton" MinWidth="100" Height="42" Content="Restart" Click="RestartButton_Click" Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Page>
