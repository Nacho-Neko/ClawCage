<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClawCage.WinUI.Pages.IntegrationAccessPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ClawCage.WinUI.Converters"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Page Header ── -->
        <Grid Padding="24,20,24,16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="3">
                <TextBlock FontSize="26" FontWeight="SemiBold" Text="服务接入"/>
                <TextBlock FontSize="13" Opacity="0.6" Text="管理外部服务接入与连接配置"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="StatusText" FontSize="12" Opacity="0.65" Text="就绪"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Spacing="8">
                <Button Click="AddIntegrationButton_Click"
                        Width="34" Height="34" Padding="0" VerticalAlignment="Center"
                        ToolTipService.ToolTip="增加接入">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="15"/>
                </Button>
                <Button Click="ReloadButton_Click"
                        Width="34" Height="34" Padding="0" VerticalAlignment="Center"
                        ToolTipService.ToolTip="刷新">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="15"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Header Divider -->
        <Rectangle Grid.Row="1" Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- ── Waterfall Card Grid ── -->
        <ScrollViewer Grid.Row="2" Padding="24,16,24,24">
            <ItemsControl ItemsSource="{x:Bind IntegrationItems, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       ItemWidth="160" ItemHeight="200"
                                       HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="0,0,10,10"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Padding="0"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                            <Grid Padding="12,12,12,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Icon -->
                                <Grid Grid.Row="0" Width="40" Height="40"
                                      HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <Border CornerRadius="10"
                                            Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            Visibility="{Binding HasIcon, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8F9;"
                                                  FontSize="18" Foreground="White"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border CornerRadius="10"
                                            BorderThickness="1"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            Background="White" Padding="4"
                                            Visibility="{Binding HasIcon, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Image Source="{Binding IconSource}" Stretch="Uniform"/>
                                    </Border>
                                </Grid>

                                <!-- Row 1: Toggle switch (centered, below icon) -->
                                <ToggleSwitch Grid.Row="1"
                                              IsOn="{Binding IsAllowed}"
                                              HorizontalAlignment="Center"
                                              MinWidth="0" MinHeight="0"
                                              Margin="0,0,0,4"
                                              Tag="{Binding}"
                                              Toggled="CardToggle_Toggled"/>

                                <!-- Row 2: Name -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding Name}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"
                                           Margin="0,0,0,2"/>

                                <!-- Row 3: Version + Update button -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal"
                                            HorizontalAlignment="Center" Spacing="4"
                                            VerticalAlignment="Top"
                                            Margin="0,0,0,6">
                                    <TextBlock Text="{Binding VersionText}"
                                               FontSize="10" Opacity="0.5"
                                               VerticalAlignment="Center"/>
                                    <Button Padding="3,1" MinWidth="0" MinHeight="0"
                                            Height="18"
                                            ToolTipService.ToolTip="检查更新"
                                            Tag="{Binding}"
                                            Click="UpdateButton_Click">
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE72C;" FontSize="9"/>
                                    </Button>
                                </StackPanel>

                                <!-- Row 4: Configure + Uninstall -->
                                <Grid Grid.Row="4" ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            HorizontalAlignment="Stretch" Height="26"
                                            Padding="0"
                                            ToolTipService.ToolTip="配置"
                                            Tag="{Binding}"
                                            Click="ConfigureButton_Click">
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE713;" FontSize="11"/>
                                    </Button>

                                    <Button Grid.Column="1"
                                            HorizontalAlignment="Stretch" Height="26"
                                            Padding="0"
                                            ToolTipService.ToolTip="卸载"
                                            Tag="{Binding}"
                                            Click="UninstallButton_Click">
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE74D;" FontSize="11"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
