<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClawCage.WinUI.Pages.InitialDeployPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:ClawCage.WinUI.ViewModels"
    x:Name="RootPage"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
        <Style x:Key="BodyTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
        <Style x:Key="BodyStrongTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="TitleLargeTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Padding="40,32,40,20" Spacing="4">
            <TextBlock Text="初始化部署" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="配置以下运行环境后即可进入 ClawCage。" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.7"/>
        </StackPanel>

        <!-- Environment table -->
        <ScrollViewer Grid.Row="1" Padding="40,0,40,0">
            <StackPanel Spacing="12">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8,8,0,0" Padding="20,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="运行环境" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="当前版本" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="目标版本" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="操作" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Padding="20,24" Visibility="{x:Bind ViewModel.DependencyPlaceholderVisibility, Mode=OneWay}">
                            <TextBlock Text="暂无依赖项" HorizontalAlignment="Center" Opacity="0.6"/>
                        </Border>

                        <ItemsControl ItemsSource="{x:Bind ViewModel.DependencyItems, Mode=OneWay}" Visibility="{x:Bind ViewModel.DependencyListVisibility, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:DependencyCardItem">
                                    <Grid Padding="20,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" ColumnSpacing="10" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="48" Height="48" CornerRadius="12" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                                <Grid>
                                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="{x:Bind IconGlyph}" Visibility="{x:Bind IconGlyphVisibility, Mode=OneWay}" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{x:Bind IconImage, Mode=OneWay}" Visibility="{x:Bind IconImageVisibility, Mode=OneWay}" Stretch="Uniform" Margin="10"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                                <TextBlock Text="{x:Bind Description}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <ProgressRing IsActive="True" Width="14" Height="14" Visibility="{x:Bind DetectRingVisibility, Mode=OneWay}"/>
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="{x:Bind StatusGlyph, Mode=OneWay}" Foreground="{x:Bind StatusForeground, Mode=OneWay}" FontSize="13" Visibility="{x:Bind StatusIconVisibility, Mode=OneWay}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind CurrentVersionText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid Grid.Column="2">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Visibility="{x:Bind TargetVersionSelectorVisibility, Mode=OneWay}">
                                                <ProgressRing Width="14" Height="14" IsActive="{Binding ViewModel.IsNodeVersionLoading, ElementName=RootPage}" Visibility="{Binding ViewModel.NodeVersionLoadingVisibility, ElementName=RootPage}" VerticalAlignment="Center"/>
                                                <ComboBox ItemsSource="{Binding ViewModel.NodeVersions, ElementName=RootPage}"
                                                          SelectedItem="{Binding ViewModel.SelectedNodeVersion, ElementName=RootPage, Mode=TwoWay}"
                                                          SelectionChanged="NodeVersionComboBox_SelectionChanged"
                                                          IsEnabled="{Binding ViewModel.IsNodeVersionComboEnabled, ElementName=RootPage}"
                                                          MinWidth="188" MaxWidth="200" PlaceholderText="加载版本列表…"/>
                                                <Button Width="24"
                                                        Height="24"
                                                        MinWidth="24"
                                                        MinHeight="24"
                                                        Padding="0"
                                                        CornerRadius="12"
                                                        Visibility="{Binding ViewModel.VersionRequirementButtonVisibility, ElementName=RootPage}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding ViewModel.ShowVersionRequirementCommand, ElementName=RootPage}">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="{Binding ViewModel.VersionRequirementIconGlyph, ElementName=RootPage}" Foreground="{Binding ViewModel.VersionRequirementForeground, ElementName=RootPage}" FontSize="12" VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind TargetVersionText}" Visibility="{x:Bind TargetVersionTextVisibility, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                        </Grid>

                                        <Grid Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="安装" MinWidth="76" Visibility="{x:Bind InstallButtonVisibility, Mode=OneWay}" Command="{Binding ViewModel.DependencyInstallCommand, ElementName=RootPage}" CommandParameter="{x:Bind Kind}"/>
                                                <Button Content="卸载" MinWidth="64" Visibility="{x:Bind UninstallButtonVisibility, Mode=OneWay}" Command="{Binding ViewModel.DependencyUninstallCommand, ElementName=RootPage}" CommandParameter="{x:Bind Kind}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{x:Bind DownloadPanelVisibility, Mode=OneWay}">
                                                <Grid Width="52" Height="52" VerticalAlignment="Center">
                                                    <ProgressRing Width="52" Height="52" Minimum="0" Maximum="100" Value="{x:Bind DownloadValue, Mode=OneWay}" IsIndeterminate="{x:Bind DownloadIndeterminate, Mode=OneWay}"/>
                                                    <TextBlock Text="{x:Bind DownloadPercentText, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                                </Grid>
                                                <StackPanel VerticalAlignment="Center" Spacing="2" MinWidth="100">
                                                    <TextBlock Text="{x:Bind DownloadPhaseText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                                    <TextBlock Text="{x:Bind DownloadSizeText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                                </StackPanel>
                                                <Button Content="取消" MinWidth="60" VerticalAlignment="Center" Command="{Binding ViewModel.DependencyCancelCommand, ElementName=RootPage}" CommandParameter="{x:Bind Kind}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Padding="40,16,40,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{x:Bind ViewModel.BackCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="返回重选路径"/>
                </StackPanel>
            </Button>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Content="重新检测" IsEnabled="{x:Bind ViewModel.IsRecheckEnabled, Mode=OneWay}" Command="{x:Bind ViewModel.DetectEnvironmentCommand}"/>
                <Button Style="{StaticResource AccentButtonStyle}" IsEnabled="{x:Bind ViewModel.IsContinueEnabled, Mode=OneWay}" Command="{x:Bind ViewModel.ContinueCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="开始部署"/>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72A;" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>