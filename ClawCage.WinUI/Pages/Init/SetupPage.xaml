<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClawCage.WinUI.Pages.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Border
            MaxWidth="520"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="48,40">

            <StackPanel Spacing="20">

                <!-- Icon + Title -->
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <FontIcon
                        FontFamily="Segoe MDL2 Assets"
                        Glyph="&#xECAA;"
                        FontSize="52"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="欢迎使用"
                        Style="{StaticResource TitleLargeTextBlockStyle}"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="Agent 部署 · 运行 · 控制平台"
                        Style="{StaticResource BodyTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Opacity="0.6"/>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                <!-- Database path section -->
                <StackPanel Spacing="8">
                    <TextBlock
                        Text="初始化设置"
                        Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock
                        Text="选择或输入 ClawCage 用于存储 Agent 配置、状态及日志数据的路径。"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Opacity="0.7"
                        TextWrapping="Wrap"/>

                    <Grid Margin="0,4,0,0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="PathTextBox"
                            Grid.Column="0"
                            PlaceholderText="输入路径或点击浏览选择…"
                            TextChanged="PathTextBox_TextChanged"/>
                        <Button
                            x:Name="BrowseButton"
                            Grid.Column="1"
                            Content="浏览"
                            Click="BrowseButton_Click"/>
                    </Grid>
                    <TextBlock
                        x:Name="PathHintText"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Opacity="0.6"
                        Visibility="Collapsed"/>
                </StackPanel>

                <!-- Start button -->
                <Button
                    x:Name="StartButton"
                    Content="开始使用"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="False"
                    Margin="0,8,0,0"
                    Click="StartButton_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
