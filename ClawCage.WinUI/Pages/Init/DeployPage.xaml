<Page x:Class="ClawCage.WinUI.Pages.DeployPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TopBar" Visibility="Collapsed" ColumnSpacing="12" MinHeight="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="DeployProgressBar" IsIndeterminate="True" Height="6" VerticalAlignment="Center"/>
            <Button x:Name="ActionButton" Grid.Column="1" Content="停止" Click="ActionButton_Click" MinWidth="92"/>
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel x:Name="IdlePanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="96" HorizontalAlignment="Center"/>
                <TextBlock Text="OpenClaw 部署" FontSize="24" HorizontalAlignment="Center"/>
                <Button Content="部署" Click="CenterDeployButton_Click" HorizontalAlignment="Center" MinWidth="140"/>
            </StackPanel>

            <Border x:Name="ConsoleHost" Visibility="Collapsed" Background="#101010" CornerRadius="10" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ConsoleText" FontFamily="Cascadia Mono" Foreground="#8CFF8C" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <StackPanel x:Name="FailurePanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="88" Foreground="Red" HorizontalAlignment="Center"/>
                <TextBlock Text="部署失败" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="失败日志:" VerticalAlignment="Center"/>
                    <HyperlinkButton x:Name="FailureLogLink" Content="查看日志" Click="FailureLogLink_Click"/>
                </StackPanel>
                <Button Content="重新部署" Click="RedeployButton_Click" MinWidth="140" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel x:Name="SuccessPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="88" Foreground="#16A34A" HorizontalAlignment="Center"/>
                <TextBlock Text="部署成功" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <Button Content="进入软件" Click="EnterSoftwareButton_Click" MinWidth="160" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
