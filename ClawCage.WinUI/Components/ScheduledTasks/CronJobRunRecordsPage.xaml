<Page x:Class="ClawCage.WinUI.Pages.CronJobRunRecordsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Padding="24,20,24,16">
            <StackPanel Spacing="3">
                <TextBlock x:Name="TitleText" FontSize="26" FontWeight="SemiBold" Text="执行记录"/>
                <TextBlock x:Name="JobInfoText" FontSize="13" Opacity="0.6" Text=""/>
            </StackPanel>
        </Grid>
        <ScrollViewer Grid.Row="1" Padding="24,16,24,24">
            <StackPanel x:Name="RunRecordsPanel" Spacing="8"/>
        </ScrollViewer>
    </Grid>
</Page>
