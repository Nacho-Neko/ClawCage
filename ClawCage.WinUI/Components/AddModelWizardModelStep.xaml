<UserControl
    x:Class="ClawCage.WinUI.Components.AddModelWizardModelStep"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MinWidth="580" Spacing="10">
        <TextBox x:Name="ModelIdBox" Header="Model ID"/>
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <NumberBox x:Name="ContextWindowBox"
                       Header="ContextWindow *"
                       SpinButtonPlacementMode="Compact"
                       Minimum="1"
                       SmallChange="1024"
                       LargeChange="4096"/>
            <NumberBox x:Name="MaxTokensBox"
                       Grid.Column="1"
                       Header="MaxTokens *"
                       SpinButtonPlacementMode="Compact"
                       Minimum="1"
                       SmallChange="1024"
                       LargeChange="4096"/>
        </Grid>
        <Button x:Name="TestButton"
                Content="测试"
                MinWidth="82"
                HorizontalAlignment="Left"
                Click="TestButton_Click"/>
        <TextBlock x:Name="TestText" Opacity="0.7"/>
    </StackPanel>

</UserControl>