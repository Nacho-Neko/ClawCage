<UserControl
    x:Class="ClawCage.WinUI.Components.AddModelWizardChooseStep"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer MaxHeight="620">
        <StackPanel MinWidth="780" Spacing="12">

            <StackPanel x:Name="ToggleRow" Orientation="Horizontal" Spacing="16">
                <RadioButton x:Name="UseExistingToggle"
                             Content="使用现有供应商"
                             IsChecked="True"
                             Checked="UseExistingToggle_Checked"/>
                <RadioButton x:Name="UseNewToggle"
                             Content="新增供应商"
                             Checked="UseNewToggle_Checked"/>
            </StackPanel>

            <GridView x:Name="ExistingProviderGrid"
                      SelectionMode="Single"
                      IsItemClickEnabled="False"
                      MinHeight="380">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="238" Height="96" CornerRadius="8" Padding="12,10"
                                Margin="0,0,10,10"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.7" TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <GridView x:Name="NewProviderGrid"
                      SelectionMode="Single"
                      IsItemClickEnabled="False"
                      MinHeight="380"
                      Visibility="Collapsed">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="238" CornerRadius="8" Padding="12,10"
                                Margin="0,0,10,10"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8" VerticalAlignment="Center"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Background="White" Padding="4">
                                    <Image Source="{Binding Icon}"
                                           Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11" Opacity="0.7"
                                               TextWrapping="WrapWholeWords"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

        </StackPanel>
    </ScrollViewer>

</UserControl>
