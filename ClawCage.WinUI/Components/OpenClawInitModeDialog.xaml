<UserControl
    x:Class="ClawCage.WinUI.Components.OpenClawInitModeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel x:Name="RootPanel" Spacing="16" MinWidth="480">

        <TextBlock Text="请选择 OpenClaw 运行模式"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Margin="0,0,0,4"
                   TextWrapping="Wrap"/>

        <!-- Gateway 模式卡片 -->
        <Border x:Name="GatewayCardBorder"
                CornerRadius="8"
                BorderThickness="1"
                Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <RadioButton x:Name="GatewayRadio"
                         GroupName="InitMode"
                         Checked="ModeRadio_Checked"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         HorizontalContentAlignment="Left">
                <Grid ColumnSpacing="16" Margin="4,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0"
                              Glyph="&#xE83B;"
                              FontSize="28"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Gateway 模式(默认)"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="作为网关，统筹集群并接收发往 Node 节点的请求"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </RadioButton>
        </Border>

        <!-- Node 模式卡片 -->
        <Border x:Name="NodeCardBorder"
                CornerRadius="8"
                BorderThickness="1"
                Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <RadioButton x:Name="NodeRadio"
                         GroupName="InitMode"
                         Checked="ModeRadio_Checked"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         HorizontalContentAlignment="Left">
                <Grid ColumnSpacing="16" Margin="4,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0"
                              Glyph="&#xE7C3;"
                              FontSize="28"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Node 模式"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="作为计算节点，连接远程 Gateway 并加入集群"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </RadioButton>
        </Border>

        <!-- 连接参数（仅 Node 模式展示） -->
        <StackPanel x:Name="NodeSettingsPanel" 
                    Spacing="12" 
                    Visibility="Collapsed"
                    Margin="0,8,0,0">
            <TextBlock Text="远程 Gateway 连接设置" 
                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <Border CornerRadius="8"
                    BorderThickness="1"
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="150"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="HostBox"
                             Header="IP 地址或域名"
                             PlaceholderText="例如: 127.0.0.1" />

                    <TextBox Grid.Column="1"
                             x:Name="PortBox"
                             Header="端口"
                             PlaceholderText="3000" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- 校验提示 -->
        <InfoBar x:Name="HintBar"
                 IsOpen="False"
                 Severity="Error"
                 IsClosable="False" />
    </StackPanel>
</UserControl>
