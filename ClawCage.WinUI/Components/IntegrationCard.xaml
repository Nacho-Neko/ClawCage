<UserControl
    x:Class="ClawCage.WinUI.Components.IntegrationCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Expander IsExpanded="True"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch">

        <Expander.Header>
            <Grid Margin="0,2,12,2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Grid Width="36" Height="36" VerticalAlignment="Center">
                    <Border x:Name="DefaultIconBorder" Width="36" Height="36" CornerRadius="8"
                            Background="{ThemeResource SystemFillColorSuccessBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8F9;" FontSize="15"
                                  Foreground="White"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="IntegrationIconBorder" Width="36" Height="36" CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="White" Padding="4" Visibility="Collapsed">
                        <Image x:Name="IntegrationIconImage"
                               Stretch="Uniform"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Name + Type + Status badge -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Item.Name, ElementName=Root}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock FontSize="12" Opacity="0.55" Text="{Binding Item.TypeText, ElementName=Root}" VerticalAlignment="Center"/>
                        <Border Background="{Binding Item.StatusColor, ElementName=Root}"
                                CornerRadius="4" Padding="6,1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Item.EnabledText, ElementName=Root}"
                                       FontSize="10" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Click="EditButton_Click"
                            Width="34" Height="34" Padding="0"
                            ToolTipService.ToolTip="编辑接入">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="14"/>
                    </Button>
                    <Button Click="DeleteButton_Click"
                            Width="34" Height="34" Padding="0"
                            ToolTipService.ToolTip="删除接入">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE74D;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Expander.Header>

        <!-- Expanded body -->
        <StackPanel Spacing="14" Padding="4,4,4,10">
            <TextBlock Text="{Binding Item.DescriptionText, ElementName=Root}"
                       FontSize="12" Opacity="0.65"
                       TextWrapping="Wrap"/>

            <Border CornerRadius="8" BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <ItemsControl ItemsSource="{Binding Item.ConfigEntries, ElementName=Root}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="12" Opacity="0.5" Text="{Binding Key}"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" FontSize="13"
                                           Text="{Binding Value}"
                                           TextWrapping="WrapWholeWords"
                                           IsTextSelectionEnabled="True"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>

    </Expander>
</UserControl>
