<UserControl
    x:Class="ClawCage.WinUI.Components.ProviderCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Expander IsExpanded="True"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch">

        <Expander.Header>
            <Grid Margin="0,2,12,2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="36" Height="36" CornerRadius="8" VerticalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B2;" FontSize="15"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Item.Name, ElementName=Root}"/>
                    <TextBlock FontSize="12" Opacity="0.55" Text="{Binding Item.ModelsCountText, ElementName=Root}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="编辑"
                        Click="EditProviderButton_Click"
                        MinWidth="64" VerticalAlignment="Center"/>
            </Grid>
        </Expander.Header>

        <StackPanel Spacing="14" Padding="4,4,4,10">
            <Border CornerRadius="8" BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock FontSize="12" Opacity="0.5" Text="BaseUrl" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" FontSize="13"
                               Text="{Binding Item.BaseUrlText, ElementName=Root}"
                               TextWrapping="WrapWholeWords"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="1" FontSize="12" Opacity="0.5" Text="Api" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="13"
                               Text="{Binding Item.ApiText, ElementName=Root}"
                               TextWrapping="WrapWholeWords"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="2" FontSize="12" Opacity="0.5" Text="ApiKey" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="13"
                               Text="{Binding Item.ApiKeyMasked, ElementName=Root}"
                               FontFamily="Cascadia Mono"
                               Opacity="0.85"/>
                </Grid>
            </Border>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="模型列表" FontSize="12" FontWeight="SemiBold"
                           Opacity="0.5" VerticalAlignment="Center"/>
                <Rectangle Grid.Column="1" Height="1" VerticalAlignment="Center"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            </Grid>

            <GridView ItemsSource="{Binding Item.Models, ElementName=Root}"
                      SelectionMode="None"
                      IsItemClickEnabled="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="278"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,10,10"/>
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="264" Padding="14,12" CornerRadius="10"
                                BorderThickness="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" Opacity="0.5"
                                                   Text="{Binding IdText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Tag="{Binding}"
                                            Click="EditModelButton_Click"
                                            Width="30" Height="30" Padding="0"
                                            VerticalAlignment="Top">
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="&#xE70F;" FontSize="12"/>
                                    </Button>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="11" Opacity="0.7" Text="{Binding InputText}"/>
                                    <TextBlock FontSize="11" Opacity="0.7" Text="{Binding ContextText}"/>
                                    <TextBlock FontSize="11" Opacity="0.7" Text="{Binding MaxTokensText}"/>
                                </StackPanel>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border CornerRadius="4" Padding="5,2"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <TextBlock FontSize="10" Opacity="0.7"
                                                   Text="{Binding ReasoningText}"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="5,2" MaxWidth="160"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <TextBlock FontSize="10" Opacity="0.7"
                                                   Text="{Binding CostText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </Expander>
</UserControl>
