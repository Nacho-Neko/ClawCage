<UserControl
    x:Class="ClawCage.WinUI.Components.ProviderCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">

    <Expander IsExpanded="True"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch">

        <Expander.Header>
            <Grid Margin="0,2,12,2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Width="36" Height="36" VerticalAlignment="Center">
                    <Border x:Name="DefaultIconBorder" Width="36" Height="36" CornerRadius="8"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B2;" FontSize="15"
                                  Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="ProviderIconBorder" Width="36" Height="36" CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="White" Padding="4" Visibility="Collapsed">
                        <Image x:Name="ProviderIconImage"
                               Stretch="Uniform"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Item.Name, ElementName=Root}"/>
                    <TextBlock FontSize="12" Opacity="0.55" Text="{Binding Item.ModelsCountText, ElementName=Root}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Click="AddModelButton_Click"
                            Width="34" Height="34" Padding="0"
                            ToolTipService.ToolTip="添加模型">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="14"/>
                    </Button>
                    <Button Click="EditProviderButton_Click"
                            Width="34" Height="34" Padding="0"
                            ToolTipService.ToolTip="编辑供应商">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="14"/>
                    </Button>
                    <Button Click="DeleteProviderButton_Click"
                            Width="34" Height="34" Padding="0"
                            ToolTipService.ToolTip="删除供应商">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE74D;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Expander.Header>

        <StackPanel Spacing="14" Padding="4,4,4,10">
            <Border CornerRadius="8" BorderThickness="1" Padding="14,12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock FontSize="12" Opacity="0.5" Text="BaseUrl" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" FontSize="13"
                               Text="{Binding Item.BaseUrlText, ElementName=Root}"
                               TextWrapping="WrapWholeWords"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="1" FontSize="12" Opacity="0.5" Text="Api" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="13"
                               Text="{Binding Item.ApiText, ElementName=Root}"
                               TextWrapping="WrapWholeWords"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Grid.Row="2" FontSize="12" Opacity="0.5" Text="ApiKey" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="13"
                               Text="{Binding Item.ApiKeyMasked, ElementName=Root}"
                               FontFamily="Cascadia Mono"
                               Opacity="0.85"/>
                </Grid>
            </Border>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="模型列表" FontSize="12" FontWeight="SemiBold"
                           Opacity="0.5" VerticalAlignment="Center"/>
                <Rectangle Grid.Column="1" Height="1" VerticalAlignment="Center"
                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            </Grid>

            <GridView ItemsSource="{Binding Item.Models, ElementName=Root}"
                      SelectionMode="None"
                      IsItemClickEnabled="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="260"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,8,8"/>
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="248" Padding="14,12" CornerRadius="8"
                                BorderThickness="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Title + Actions -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Spacing="1">
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" Opacity="0.45"
                                                   FontFamily="Cascadia Mono"
                                                   Text="{Binding IdText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                Spacing="2" VerticalAlignment="Top">
                                        <Button Tag="{Binding}"
                                                Click="EditModelButton_Click"
                                                Width="28" Height="28" Padding="0"
                                                Background="Transparent" BorderThickness="0">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      Glyph="&#xE70F;" FontSize="11"/>
                                        </Button>
                                        <Button Tag="{Binding}"
                                                Click="DeleteModelButton_Click"
                                                Width="28" Height="28" Padding="0"
                                                Background="Transparent" BorderThickness="0">
                                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                                      Glyph="&#xE74D;" FontSize="11"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Specs -->
                                <Grid Grid.Row="1" ColumnSpacing="6" RowSpacing="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock FontSize="10" Opacity="0.4" Text="Input" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontSize="11" Opacity="0.7" Text="{Binding InputText}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="1" FontSize="10" Opacity="0.4" Text="Context" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11" Opacity="0.7" Text="{Binding ContextText}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="2" FontSize="10" Opacity="0.4" Text="Tokens" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Opacity="0.7" Text="{Binding MaxTokensText}" TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <!-- Tags -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="5">
                                    <Border CornerRadius="10" Padding="7,2"
                                            Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                        <TextBlock FontSize="10" Opacity="0.65"
                                                   Text="{Binding ReasoningText}"/>
                                    </Border>
                                    <Border CornerRadius="10" Padding="7,2" MaxWidth="140"
                                            Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                        <TextBlock FontSize="10" Opacity="0.65"
                                                   Text="{Binding CostText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </Expander>
</UserControl>
