<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ClawCage.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClawCage.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ClawCage">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Frame x:Name="RootFrame"/>

        <Border x:Name="UpdateCheckingBanner"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,16,0,0"
                Padding="16,8,20,8"
                CornerRadius="20"
                BorderThickness="1"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Visibility="Collapsed"
                Translation="0,0,32">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <ProgressRing Width="16" Height="16" IsActive="True"/>
                <TextBlock x:Name="UpdateCheckingText"
                           Text="正在检查更新..."
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <InfoBar x:Name="UpdateInfoBar"
                 Title="检查完成"
                 Message="当前已是最新版本"
                 Severity="Informational"
                 IsClosable="False"
                 IsOpen="False"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Margin="0,20,0,0"
                 MinWidth="520"
                 MaxWidth="720"/>
    </Grid>
</Window>
